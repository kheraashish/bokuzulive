# Bokuzu portal environment variables.
# Local dev: copy to .env.local and fill in (gitignored, never committed).
# Production: set these in Hostinger -> Environment variables.

# --- MySQL database (from Hostinger -> Databases -> Management) ---
# Local testing connects over Remote MySQL; on Hostinger the host is usually "localhost".
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u460330975_bokuzuportal
DB_USER=u460330975_bokuzuportal
DB_PASSWORD=

# --- Encryption key for stored ad-account tokens (generate: openssl rand -hex 32) ---
TOKEN_ENC_KEY=

# --- Operator console password (protects the /admin onboarding screen) ---
OPERATOR_KEY=

# --- Secret that authorizes the daily sync trigger (GitHub Action sends this) ---
SYNC_SECRET=

# --- Google Ads (fill after you create the app + get the developer token) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Meta / Facebook (fill after you create the app + pass App Review) ---
META_APP_ID=
META_APP_SECRET=

# --- Public site URL, used to build OAuth redirect URLs ---
APP_BASE_URL=https://bokuzu.com
